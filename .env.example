# Supabase Configuration
# Update these values in your local .env file or Vercel environment variables.
# Both Supabase key formats work here with no code changes: the legacy
# JWT-shaped anon/service_role keys, and the newer sb_publishable_.../
# sb_secret_... keys - lib/config.js only checks that these are present and
# don't look like placeholder text, never their shape, and lib/supabaseClient.js
# passes whichever one you set straight into the official @supabase/supabase-js
# createClient() call, which is the version-compatible way to use either key
# format (never decoded/parsed as a JWT by this codebase).
SUPABASE_URL=https://your-project-ref.supabase.co
# Also accepted: NEXT_PUBLIC_SUPABASE_URL (same value) - useful if you already
# set that name for a frontend framework's convention.
SUPABASE_ANON_KEY=your_publishable_key_here
# Optional alias accepted by some frontend snippets; same value as SUPABASE_ANON_KEY.
SUPABASE_KEY=your_publishable_key_here
# Also accepted: NEXT_PUBLIC_SUPABASE_ANON_KEY (same value, same reason as above).
# Server-side only - the secret/service_role key. Set this to the new
# sb_secret_... "Secret key" from Supabase Dashboard -> Project Settings ->
# API Keys, or the legacy service_role JWT - either works. Never prefix this
# with NEXT_PUBLIC_ (or expose it to the browser in any other way) - it
# bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=your_secret_key_here

# Optional: enables automatic local SQL setup via `npm run db:setup`
# (runs SUPABASE_RUN_THIS.sql, supabase/migrations/*.sql, then seeds lib/seed-lessons.json)
# Get this from Supabase Dashboard -> Project Settings -> Database -> Connection string
# Format: postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
SUPABASE_DATABASE_URL=

PORT=3000

# Optional: price shown across the app for the single premium plan (USD).
PREMIUM_PRICE_USD=5.95
# Enables `npm run audio:generate` (real listening audio via TTS, uploaded to
# the "lesson-audio" Supabase Storage bucket). Not required for the AI Tutor
# (see GEMINI_API_KEY below), only for that script.
OPENAI_API_KEY=
# Optional: defaults to gpt-4.1-mini.
OPENAI_MODEL=
# Optional: defaults to tts-1. Used only by `npm run audio:generate`.
OPENAI_TTS_MODEL=

# Alternative TTS provider to OpenAI for `npm run audio:generate` and
# AI-generated Listening practice - get a key at https://elevenlabs.io.
# Both the key and a voice id are required to enable this provider; without
# them lib/ttsService.js falls back to OpenAI above.
ELEVENLABS_API_KEY=
# Required alongside ELEVENLABS_API_KEY - find/create one at
# https://elevenlabs.io/app/voice-library, then copy its id from the voice's
# "..." menu -> Copy Voice ID.
ELEVENLABS_VOICE_ID=
# Optional: defaults to eleven_multilingual_v2 (handles every ANDERGO target
# language with a single voice).
ELEVENLABS_MODEL_ID=
# Optional: "openai" or "elevenlabs". Without this set, ElevenLabs is used
# automatically once ELEVENLABS_API_KEY + ELEVENLABS_VOICE_ID are both set,
# otherwise OpenAI is used - set this to force one provider explicitly.
TTS_PROVIDER=

# Pregenerated (not live) Listening audio for Español A1, used only by
# scripts/generate-spanish-listening-audio.js --confirm (never on a normal
# page load). Reuses ELEVENLABS_API_KEY above - never prefix any of these
# with NEXT_PUBLIC_ or otherwise expose them to the browser.
ELEVENLABS_MODEL_NARRATION=eleven_multilingual_v2
ELEVENLABS_MODEL_DIALOGUE=eleven_v3
ELEVENLABS_VOICE_ES_FEMALE=
ELEVENLABS_VOICE_ES_MALE=

# AI Tutor - primary provider (fast inference, streaming). Get a key at
# https://cloud.cerebras.ai. Never expose this to the browser (no
# NEXT_PUBLIC_ prefix) - it's read server-side only, in lib/cerebrasService.js.
CEREBRAS_API_KEY=
# Optional: defaults to gpt-oss-120b.
CEREBRAS_MODEL=

# AI Tutor - fallback #2 (used only if Cerebras is unconfigured, errors, or
# doesn't start responding in time). Get a key at https://console.groq.com.
# Groq's API is OpenAI-compatible, so this reuses the `openai` package above
# instead of a separate SDK - see lib/groqService.js.
GROQ_API_KEY=
# Optional: defaults to openai/gpt-oss-20b.
GROQ_MODEL=

# AI Tutor - fallback #3 / last resort (non-streaming). Get a key at
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: defaults to gemini-3.1-flash-lite.
GEMINI_MODEL=

# Traductor (POST /api/translate) - exclusive provider is DeepL, never the AI
# Tutor providers above or ElevenLabs. Get a key at https://www.deepl.com/pro-api
# (the Free plan works here). Never expose this to the browser (no
# NEXT_PUBLIC_ prefix) - it's read server-side only, in lib/translatorService.js.
DEEPL_API_KEY=
# DeepL API Free accounts must use api-free.deepl.com (the default below).
# Paid API plans use api.deepl.com instead - set this to switch.
DEEPL_API_BASE_URL=https://api-free.deepl.com

# Optional: only used when Supabase is NOT configured, to sign the fallback
# dev-mode session tokens. Not used once SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY are set.
DEV_TOKEN_SECRET=change-me-in-your-local-env

# Account verification / MFA (Phase 1: email OTP + optional TOTP only).
# Requires the Supabase "Confirm signup" email template to use {{ .Token }}
# instead of {{ .ConfirmationURL }} - see docs/AUTH_VERIFICATION.md.
# No env var needed to enable email OTP/TOTP themselves - both are handled
# entirely through Supabase's own Auth API once the template is updated.

# Phase 2/3 - kept OFF and unused by any endpoint in this codebase today;
# do not set to true without a configured SMS/WhatsApp provider in Supabase
# (Authentication -> Providers -> Phone) first.
PHONE_AUTH_ENABLED=false
WHATSAPP_AUTH_ENABLED=false
PASSKEY_AUTH_ENABLED=false

# Contact addresses shown in the UI (footer, Acerca de) and reserved for
# future server-sent email. support@ is the public support channel - safe to
# display as a mailto: link. non-reply@ is only ever a documented *sender*
# address, never shown as a channel to write to, and must not be used to
# actually send mail until it's configured and verified with a real
# SMTP/email provider. Neither needs NEXT_PUBLIC_ - the frontend already
# hardcodes support@andergo.online as public info, same as the domain itself.
SUPPORT_EMAIL=support@andergo.online
NO_REPLY_EMAIL=non-reply@andergo.online
