# Supabase Configuration
# Update these values in your local .env file or Vercel environment variables
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_publishable_key_here
# Optional alias accepted by some frontend snippets; same value as SUPABASE_ANON_KEY.
SUPABASE_KEY=your_publishable_key_here
SUPABASE_SERVICE_ROLE_KEY=your_secret_key_here

# Optional: enables automatic local SQL setup via `npm run db:setup`
# (runs SUPABASE_RUN_THIS.sql, supabase/migrations/*.sql, then seeds lib/seed-lessons.json)
# Get this from Supabase Dashboard -> Project Settings -> Database -> Connection string
# Format: postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
SUPABASE_DATABASE_URL=

PORT=3000

# Optional: price shown across the app for the single premium plan (USD).
PREMIUM_PRICE_USD=5.95
# Enables `npm run audio:generate` (real listening audio via TTS, uploaded to
# the "lesson-audio" Supabase Storage bucket). Not required for the AI Tutor
# (see GEMINI_API_KEY below), only for that script.
OPENAI_API_KEY=
# Optional: defaults to gpt-4.1-mini.
OPENAI_MODEL=
# Optional: defaults to tts-1. Used only by `npm run audio:generate`.
OPENAI_TTS_MODEL=

# Alternative TTS provider to OpenAI for `npm run audio:generate` and
# AI-generated Listening practice - get a key at https://elevenlabs.io.
# Both the key and a voice id are required to enable this provider; without
# them lib/ttsService.js falls back to OpenAI above.
ELEVENLABS_API_KEY=
# Required alongside ELEVENLABS_API_KEY - find/create one at
# https://elevenlabs.io/app/voice-library, then copy its id from the voice's
# "..." menu -> Copy Voice ID.
ELEVENLABS_VOICE_ID=
# Optional: defaults to eleven_multilingual_v2 (handles every ANDERGO target
# language with a single voice).
ELEVENLABS_MODEL_ID=
# Optional: "openai" or "elevenlabs". Without this set, ElevenLabs is used
# automatically once ELEVENLABS_API_KEY + ELEVENLABS_VOICE_ID are both set,
# otherwise OpenAI is used - set this to force one provider explicitly.
TTS_PROVIDER=

# Enables the AI Tutor chat (free tier). Get a key at
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: defaults to gemini-flash-latest.
GEMINI_MODEL=

# Optional: only used when Supabase is NOT configured, to sign the fallback
# dev-mode session tokens. Not used once SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY are set.
DEV_TOKEN_SECRET=change-me-in-your-local-env

# Account verification / MFA (Phase 1: email OTP + optional TOTP only).
# Requires the Supabase "Confirm signup" email template to use {{ .Token }}
# instead of {{ .ConfirmationURL }} - see docs/AUTH_VERIFICATION.md.
# No env var needed to enable email OTP/TOTP themselves - both are handled
# entirely through Supabase's own Auth API once the template is updated.

# Phase 2/3 - kept OFF and unused by any endpoint in this codebase today;
# do not set to true without a configured SMS/WhatsApp provider in Supabase
# (Authentication -> Providers -> Phone) first.
PHONE_AUTH_ENABLED=false
WHATSAPP_AUTH_ENABLED=false
PASSKEY_AUTH_ENABLED=false
